# ----------------------------------------------------------------------------
# Endereços dos microserviços — um por máquina do laboratório.
#
# No laboratório:
#   1) copie este arquivo:        cp .env.example .env
#   2) descubra o IP de cada máquina de serviço:   hostname -I
#   3) troque os IPs abaixo pelos reais e salve
#   4) suba o central com:        docker run ... --env-file .env central
# ----------------------------------------------------------------------------

SOMA_URL=http://192.168.0.101:4001
SUBTRACAO_URL=http://192.168.0.102:4002
MULTIPLICACAO_URL=http://192.168.0.103:4003
DIVISAO_URL=http://192.168.0.104:4004
